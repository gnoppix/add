{
  "name": "add-desktop",
  "version": "0.2.13",
  "description": "Cross-platform desktop messaging application",
  "main": "electron/main.js",
  "author": "Add Team <team@gnoppix.org>",
  "homepage": "https://github.com/gnoppix/Add",
  "license": "MIT",
  "scripts": {
    "dev": "VITE_DEV_SERVER_URL=http://localhost:5173 concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "dev:react": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "npm run build:react && npm run fix:index && npm run build:electron",
    "build:react": "vite build",
    "build:electron": "electron-builder",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "fix:index": "node -e \"const fs=require('fs');const f='dist/index.html';let h=fs.readFileSync(f,'utf8');h=h.replace(/\\scrossorigin/g,'');fs.writeFileSync(f,h);console.log('stripped crossorigin from '+f)\""
  },
  "keywords": [
    "messaging",
    "signal",
    "electron",
    "desktop"
  ],
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0",
    "lucide-react": "^0.400.0",
    "i18next": "^24.0.0",
    "react-i18next": "^14.0.0",
    "i18next-browser-languagedetector": "^8.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^8.50.0",
    "eslint-plugin-react": "^7.34.0",
    "postcss": "^8.4.0",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.2.0",
    "vite": "^7.0.0",
    "wait-on": "^7.2.0"
  }
}
